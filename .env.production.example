# NoteVault Production Environment Variables
# Copy this file to .env.production.local and fill in the real values
# DO NOT commit .env.production.local to git!

DATABASE_URL="postgresql://notevault_user:CHANGE_ME_PASSWORD@localhost:5432/notevault"
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="CHANGE_ME_RUN: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
